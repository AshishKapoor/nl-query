# WrenAI Environment Configuration
# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=${OPENAI_API_KEY:-sk-your-openai-api-key}
GENERATION_MODEL=gpt-4o

# Trino connection (WrenAI connects through Trino for all queries)
WREN_ENGINE_ENDPOINT=http://wren-engine:8080
WREN_AI_SERVICE_ENDPOINT=http://wren-ai-service:5556
QDRANT_HOST=qdrant

# Data source
DATA_SOURCE_TYPE=trino
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_CATALOG=postgres_retail
TRINO_SCHEMA=public
