# =============================================================================
# NL-Query Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose up

# --- LLM Provider ---
# Supported: openai, anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Postgres (Retail DB) ---
POSTGRES_USER=retail_admin
POSTGRES_PASSWORD=retail_secret_2024
POSTGRES_DB=retail

# --- MySQL (Inventory DB) ---
MYSQL_ROOT_PASSWORD=mysql_root_2024
MYSQL_USER=inventory_admin
MYSQL_PASSWORD=inventory_secret_2024
MYSQL_DATABASE=inventory

# --- Trino ---
TRINO_PASSWORD=test123

# --- WrenAI ---
WREN_ENGINE_PORT=8081
WREN_AI_SERVICE_PORT=5556
WREN_UI_PORT=3000

# --- Qdrant ---
QDRANT_PORT=6333
